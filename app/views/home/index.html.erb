<section class="row">
  <div class="col-12  mt-3 mb-3">
    <div id="programCarousel"
         class="carousel slide"
         data-bs-touch="true"
         data-bs-ride="carousel">

      <!-- indicators -->
      <div class="carousel-indicators">
        <% @programs.each_with_index do |program,index| %>
          <button type="button"
                  data-bs-target="#programCarousel"
                  data-bs-slide-to="<%=index%>"
                  class="<%= 'active' if index.zero? %>">
          </button>
        <% end %>
      </div>

      <div class="carousel-inner">

        <% @programs.each_with_index do |program, index| %>

          <div class="carousel-item <%= 'active' if index.zero? %>">

            <article class="media rounded p-3 mb-3">

              <h2>
                <%= link_to program.title, program_path(program.id) %>
              </h2>

              <p>
                <%= raw program.description %>
              </p>

              <% unless program.program_pictures_count.zero? %>
                <ul class="row">
                  <% program.program_pictures.each do |program_picture| %>
                    <li class="col-6 col-lg-4 col-xxl-3">
                      <!-- <picture>
                        <source srcset="/logo-dark.png" media="(prefers-color-scheme: dark)">
                        <img src="/logo-light.png" alt="logo">
                      </picture> -->
                      <figure>
                        <%= image_tag program_picture.picture.small_thumb.url,
                                      class: "img-dark" %>
                      </figure>
                    </li>
                  <% end %>
                </ul>
              <% end %>

            </article>

          </div>

        <% end %>

      </div>

      <!-- controls -->
      <button class="carousel-control-prev d-none d-md-flex"
              type="button"
              data-bs-target="#programCarousel"
              data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
      </button>

      <button class="carousel-control-next d-none d-md-flex"
              type="button"
              data-bs-target="#programCarousel"
              data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
      </button>

    </div>


  </div>
</section>
  <section class="row main-section">
    <article id="program-free" class="col-12 mt-3 mb-3">
